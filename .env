################################
# IMAGES
################################

BACKEND_IMAGE=rag-backend-image
FRONT_USER_IMAGE=rag-frontend-user-image
FRONT_ADMIN_IMAGE=rag-frontend-admin-image

MONGO_IMAGE=mongo:7
MYSQL_IMAGE=mysql:8
WEAVIATE_IMAGE=semitechnologies/weaviate:1.29.3
OLLAMA_IMAGE=ollama/ollama

################################
# CONTAINERS
################################

BACKEND_CONTAINER=rag-backend
FRONT_USER_CONTAINER=rag-frontend-user
FRONT_ADMIN_CONTAINER=rag-frontend-admin

MONGO_CONTAINER=mongodb
MYSQL_CONTAINER=rag-mysql
WEAVIATE_CONTAINER=rag-weaviate
OLLAMA_CONTAINER=ollama

################################
# PORTS
################################

BACKEND_PORT=8000
FRONT_USER_PORT=5173
FRONT_ADMIN_PORT=5174

MONGO_PORT=27017
MYSQL_PORT=3306
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
OLLAMA_PORT=11434
PHOENIX_PORT=6006
NGINIX_PORT=8081

################################
# INTERNAL PORTS
################################

BACKEND_INTERNAL_PORT=8000
FRONT_INTERNAL_PORT=80

MONGO_INTERNAL_PORT=27017
MYSQL_INTERNAL_PORT=3306
WEAVIATE_INTERNAL_PORT=8080
WEAVIATE_GRPC_INTERNAL_PORT=50051
OLLAMA_INTERNAL_PORT=11434
NGINIX_INTERNAL_PORT=8080

################################
# VOLUMES
################################

MONGO_VOLUME=mongo_data
MYSQL_VOLUME=mysql_data
WEAVIATE_VOLUME=weaviate_data
OLLAMA_VOLUME=ollama_data

################################
# DATA PATHS
################################

MONGO_DATA_PATH=/data/db
MYSQL_DATA_PATH=/var/lib/mysql
WEAVIATE_DATA_PATH=/var/lib/weaviate
OLLAMA_DATA_PATH=/root/.ollama

################################
# MYSQL CONFIG (for container)
################################

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=fashion_rag
MYSQL_USER=raguser
MYSQL_PASSWORD=ragpassword

################################
# WEAVIATE CONFIG
################################

WEAVIATE_QUERY_LIMIT=25
WEAVIATE_ANON_ACCESS=true
WEAVIATE_VECTORIZER=text2vec-transformers

################################
# OLLAMA MODEL
################################

OLLAMA_MODEL=llama3.1:8b